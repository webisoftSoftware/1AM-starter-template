# 1AM wallet network used by wallet.connect(...)
# Also used as Docker build arg in docker-compose.yml
# Allowed values: preview, preprod
VITE_1AM_NETWORK=preview

# Public zk asset path for the unshielded TODO contract
# Also used as Docker build arg in docker-compose.yml
VITE_ZK_TODO_ASSET_BASE_PATH=/zk/todo

# Public zk asset path for the shielded TODO contract
# Also used as Docker build arg in docker-compose.yml
VITE_ZK_SHIELDED_TODO_ASSET_BASE_PATH=/zk/shieldedTodo

# Public zk asset path for the shielded mint contract
# Also used as Docker build arg in docker-compose.yml
VITE_ZK_MINT_ASSET_BASE_PATH=/zk/shieldedMint

# Optional: only needed if replacing the bundled Midnight system zk assets
# served from public/zk/shieldedMint/{keys,zkir}/midnight.
# MIDNIGHT_SYSTEM_KEYS_DIR=/path/to/system-keys

# Comma-separated hostnames allowed by the Vite dev server
# Example: localhost,example.com
DEV_ALLOWED_HOSTS=localhost,example.com
